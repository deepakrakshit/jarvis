# 🔐 Runtime Secrets (REQUIRED)
HF_TOKEN=your_huggingface_token
GEMINI_API_KEY=your_gemini_api_key


# 🤖 Model Configuration
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_SEARCH_MODEL=gemini-2.5-flash
PIPER_PATH=venv/Scripts/piper.exe
PIPER_MODEL_PATH=models/piper/en_US-ryan-medium.onnx
PIPER_CONFIG_PATH=models/piper/en_US-ryan-medium.onnx.json
PIPER_MODEL_URL=https://huggingface.co/rhasspy/piper-voices/resolve/main/en/en_US/ryan/medium/en_US-ryan-medium.onnx
PIPER_CONFIG_URL=https://huggingface.co/rhasspy/piper-voices/resolve/main/en/en_US/ryan/medium/en_US-ryan-medium.onnx.json
GEMINI_REQUEST_TIMEOUT_SECONDS=25
GEMINI_RESPONSE_MAX_TOKENS=160


# 🔊 TTS Performance Tuning
TTS_CHUNK_CHARS=42
TTS_FIRST_CHUNK_DELAY=0.00
TTS_QUEUE_TIMEOUT=0.02
TTS_FRAMES_PER_BUFFER=1024
TTS_PLAYOUT_CHUNK_SIZE=2048
TTS_MIN_SENTENCE_LENGTH=16
TTS_MIN_FIRST_FRAGMENT_LENGTH=14
TTS_FORCE_FIRST_FRAGMENT_AFTER_WORDS=22
TTS_WAIT_FOR_COMPLETION=false


# 🧠 Context & Memory
MAX_CONTEXT_MESSAGES=12
MEMORY_STORE_PATH=data/user_memory.json


# 📄 Document Intelligence System
DOCUMENT_DEEP_MODEL=gemini-3.1-flash-lite-preview
DOCUMENT_CACHE_ENABLED=true
DOCUMENT_CACHE_DB_PATH=data/document_cache.sqlite3
DOCUMENT_CACHE_TTL_SECONDS=86400
DOCUMENT_CACHE_MAX_ENTRIES=256
DOCUMENT_OCR_MAX_IMAGE_SIDE=2000
DOCUMENT_OCR_PDF_DPI=180
DOCUMENT_OCR_PDF_MIN_DPI=48
DOCUMENT_OCR_PDF_MAX_SIDE=2000
DOCUMENT_OCR_CONFIDENCE_THRESHOLD=0.45
DOCUMENT_VISION_PRIMARY_MODEL=gemini-3.1-flash-lite-preview
DOCUMENT_VISION_FALLBACK_MODELS=
DOCUMENT_VISION_TIMEOUT_SECONDS=25
DOCUMENT_VISION_MAX_RETRIES=0
DOCUMENT_VISION_RETRY_BACKOFF_SECONDS=1.2
DOCUMENT_VISION_FAST_FAIL_ON_429=true
DOCUMENT_TEXT_PRIMARY_MAX_VISION_SUPPORT_IMAGES=3
DOCUMENT_VISION_SUPPORT_SECOND_PASS=false
DOCUMENT_VISION_MAX_WORKERS=4
DOCUMENT_OCR_MAX_WORKERS=6
DOCUMENT_PDF_RENDER_DPI=140
DOCUMENT_PDF_MAX_VISION_IMAGES=10
DOCUMENT_PDF_MAX_OCR_IMAGES=16
DOCUMENT_DOCX_MAX_VISION_IMAGES=12
DOCUMENT_REASONING_MAX_CHUNKS=10
DOCUMENT_REASONING_TEXT_CHAR_BUDGET=22000
DOCUMENT_REASONING_OCR_CHAR_BUDGET=9000
DOCUMENT_REASONING_VISION_VISIBLE_CHAR_BUDGET=7000
DOCUMENT_REASONING_VISION_LAYOUT_CHAR_BUDGET=2600
DOCUMENT_REASONING_VISION_SUMMARY_CHAR_BUDGET=2600
DOCUMENT_REASONING_FAST_PATH_THRESHOLD_CHARS=14000
DOCUMENT_REASONING_DEFAULT_FAST=true
DOCUMENT_ULTRA_FAST_ENABLED=true
DOCUMENT_ULTRA_FAST_MIN_CHARS=700
DOCUMENT_SKIP_VISION_FOR_TEXT_RICH=true
DOCUMENT_TEXT_RICH_MIN_CHARS=1800
DOCUMENT_PDF_TABLE_MAX_PAGES=8